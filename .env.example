APP_NAME=AI Restaurant Decision Assistant
APP_ENV=development
APP_VERSION=0.1.0
APP_DOCS_URL=/docs
APP_REDOC_URL=/redoc
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
CORS_ALLOW_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*
DATABASE_URL=postgresql+psycopg://app:app@localhost:5432/restaurant_decision
DATABASE_AUTO_SEED=true
SAMPLE_BUSINESSES_PATH=backend/data/samples/demo_businesses.jsonl
SAMPLE_REVIEWS_PATH=backend/data/samples/demo_reviews.jsonl
POSTGRES_DB=restaurant_decision
POSTGRES_USER=app
POSTGRES_PASSWORD=app
LLM_PROVIDER=stub
LLM_MODEL_NAME=stub-chat-model
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=256
OPENAI_API_KEY=
OPENAI_BASE_URL=
CHAT_SYSTEM_PROMPT=You are a concise assistant inside the AI Restaurant Decision Assistant backend. Answer directly and keep the response grounded in the conversation.
STUB_LLM_RESPONSE_PREFIX=Stub reply: 
STUB_LLM_DEFAULT_REPLY=Hello from the stub model.
